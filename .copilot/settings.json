{
  "autoUpdate": true,
  "theme": "dark",
  "model": "auto",
  "effortLevel": "medium",
  "footer": {
    "showModelEffort": false,
    "showDirectory": true,
    "showBranch": true,
    "showContextWindow": true,
    "showQuota": true,
    "showAgent": true,
    "showCodeChanges": true,
    "showUsername": true,
    "showCustom": false
  },
  "companyAnnouncements": [
    "📋 **Zadanie 2** "
  ],
  "disableAllHooks": false,
  "hooks": {
    "onAgentStart": "mkdir -p ~/.copilot/logs && echo \"[$(date '+%Y-%m-%d %H:%M:%S')] agent-start cwd=$(pwd)\" >> ~/.copilot/logs/sessions.log",
    "onAgentFinish": "echo \"[$(date '+%Y-%m-%d %H:%M:%S')] agent-finish\" >> ~/.copilot/logs/sessions.log",
    "onTaskStart": "echo \"[$(date '+%Y-%m-%d %H:%M:%S')] task-start\" >> ~/.copilot/logs/sessions.log",
    "onTaskFinish": "echo \"[$(date '+%Y-%m-%d %H:%M:%S')] task-finish\" >> ~/.copilot/logs/sessions.log"
  },
  "disabledSkills": [
    "security-scan"
  ],
  "disabledMcpServers": [
    "github"
  ],
  "enabledPlugins": {},
  "allowedUrls": [
    "https://gitlab.com",
    "https://docs.github.com",
    "https://api.github.com"
  ],
  "deniedUrls": [],
  "bashEnv": false,
  "beep": true,
  "respectGitignore": true,
  "experimental": true,
  "mergeStrategy": "merge",
  "keepAlive": "busy",
  "logLevel": "info",
  "telemetry": {
    "enabled": false
  }
}
